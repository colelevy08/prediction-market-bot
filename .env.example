# ============================================================================
# Prediction Market Bot — Environment Variables
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# For Railway deployment: add these as environment variables in the dashboard.
# For Vercel (frontend only): set VITE_API_URL in frontend/.env
# ============================================================================

# ── Kalshi API ──────────────────────────────────────────────────────────────
# Get credentials from https://demo.kalshi.co (demo) or https://kalshi.com (live)
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem   # Local dev: path to PEM file
# KALSHI_PRIVATE_KEY=                               # Cloud deploy: paste raw PEM content
KALSHI_USE_DEMO=true                                # true = demo, false = real money

# ── Anthropic (Optional) ───────────────────────────────────────────────────
# Enables Claude AI-powered market analysis alongside the RF model
ANTHROPIC_API_KEY=your-anthropic-api-key

# ── Supabase (Optional) ────────────────────────────────────────────────────
# Enables persistent trade history, training data, and performance snapshots
# Without Supabase, data persists locally in data/ directory (JSON files)
# Run supabase/schema.sql in the SQL editor to create required tables
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key

# ── Trading Parameters ─────────────────────────────────────────────────────
MAX_BET_AMOUNT_CENTS=2500        # $25.00 max per trade
MIN_EDGE_THRESHOLD=0.08          # Minimum 8% model-vs-market edge to enter
MAX_DAILY_LOSS_CENTS=10000       # $100.00 daily stop-loss limit
MAX_OPEN_POSITIONS=10            # Max simultaneous open positions
MAX_EVENTS_TO_ANALYZE=20         # Events per scan (auto-scan uses get_all_events)
KELLY_FRACTION=0.5               # Position sizing: 0.5 = half-Kelly (safer)

# ── Notifications (Optional) ───────────────────────────────────────────────
# Get notified on trade entries, exits, and model retrains
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your/webhook/url

# ── Webhook (Optional) ─────────────────────────────────────────────────────
# Secure external webhook endpoint for triggering scans/retrains
WEBHOOK_SECRET=your-secret-key

# ── Retrain Schedule ───────────────────────────────────────────────────────
# Automatic model retraining via APScheduler cron
RETRAIN_DAYS=mon,wed,fri         # Comma-separated: mon,tue,wed,thu,fri,sat,sun
RETRAIN_HOUR=3                   # Hour in UTC (0-23)
