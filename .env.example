# Kalshi API credentials (get from https://kalshi.com or https://demo.kalshi.co)
KALSHI_API_KEY_ID=your-api-key-id
KALSHI_PRIVATE_KEY_PATH=./kalshi_private_key.pem

# Use demo environment for testing (set to false for real trading)
KALSHI_USE_DEMO=true

# Anthropic API key for Claude-powered analysis
ANTHROPIC_API_KEY=your-anthropic-api-key

# Trading parameters
MAX_BET_AMOUNT_CENTS=2500        # $25.00 max per trade
MIN_EDGE_THRESHOLD=0.08          # Minimum 8% edge to place a trade
MAX_DAILY_LOSS_CENTS=10000       # $100.00 daily stop-loss
MAX_OPEN_POSITIONS=10            # Max concurrent positions
MAX_EVENTS_TO_ANALYZE=20         # Top events by volume to scan

# Supabase (optional — enables persistent trade history)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key
